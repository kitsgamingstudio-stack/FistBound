# Unreal Engine 5 generated directories
/Binaries/
/DerivedDataCache/
/Intermediate/
/Saved/

# Local build, staging, and packaged output
/Build/
/Packaged/
/LocalBuilds/
/Releases/
/StagedBuilds/

# Generated files inside project plugins
/Plugins/**/Binaries/
/Plugins/**/DerivedDataCache/
/Plugins/**/Intermediate/
/Plugins/**/Saved/

# Visual Studio
/.vs/
*.sln
*.slnx
*.suo
*.user
*.userosscache
*.sln.docstates
*.rsuser
*.VC.db
*.VC.VC.opendb
*.opensdf
*.opendb
*.sdf

# Rider, VS Code, Xcode, and other generated project files
/.idea/
/.vscode/
/.vsconfig.user
*.code-workspace
*.xcodeproj
*.xcworkspace
Makefile

# Unreal Build Tool metadata and compiler output
*.target
*.modules
*.version
*.obj
*.pdb
*.ilk
*.exp
*.pch

# Logs, crash dumps, and temporary files
*.log
*.tmp
*.temp
*.dmp
*.stackdump
CrashReportClient.ini

# Automation and test output
/TestResults/
/AutomationReports/

# Operating-system metadata
.DS_Store
._*
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Source-controlled Unreal project files remain tracked by default:
